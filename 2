#include <iostream>
#include <string>
using namespace std;

int contarpalabras(string frase)
{
    int cant = 1;

    for(int i = 0; i < frase.length(); i++)
    {
        if(frase[i] == ' ')
        {
            cant++;
        }
    }

    return cant;
}

int main()
{
    string frase;

    cout << "Ingrese una frase: ";
    getline(cin, frase);

    cout << "Cantidad de palabras: " << contarpalabras(frase);

    return 0;
}
